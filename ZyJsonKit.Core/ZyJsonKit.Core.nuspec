<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>ZyJsonKit.Core</id>
    <version>1.0.0</version>
    <title>ZyJsonKit.Core</title>
    <authors>Zulfy Doank</authors>
    <owners>Zulfy Doank</owners>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/Zulfy-Doank/ZyJsonKit.Core</projectUrl>
    <repository type="git" url="https://github.com/Zulfy-Doank/ZyJsonKit.Core" />
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <description>
      ZyJsonKit.Core is an enterprise-grade JSON serialization/deserialization 
      library for VB.NET, built on Newtonsoft.Json with 16 modular feature 
      groups and 66+ production-ready, thread-safe, null-safe classes.
      
      Features: JSON Parsing, Serialization, Deserialization, File Operations, 
      JObject/JToken Operations, Dictionary Conversion, List/Array Operations, 
      Formatting, Deep Clone, Dynamic Objects, Contract Resolvers, 
      Thread Safety, Production Features, Enterprise Architecture.
    </description>
    <tags>json vb.net serialization deserialization enterprise newtonsoft json.net thread-safe null-safe</tags>
    <copyright>Copyright (c) 2026 Zulfy Doank &amp; ZyJsonKit Contributors</copyright>
    <dependencies>
      <dependency id="Newtonsoft.Json" version="13.0.4" />
    </dependencies>
  </metadata>
  <files>
    <!-- DLL -->
    <file src="bin\Release\ZyJsonKit.Core.dll" target="lib\net472" />
    <file src="bin\Release\ZyJsonKit.Core.xml" target="lib\net472" />
    
    <!-- Icon & README -->
    <file src="Resources\icon.png" target="" />
    <file src="README.md" target="" />
    
    <!-- License -->
    <file src="LICENSE" target="" />
  </files>
</package>